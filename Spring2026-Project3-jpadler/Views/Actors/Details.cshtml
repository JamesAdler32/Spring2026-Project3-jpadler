@model Spring2026_Project3_jpadler.Models.ActorMoviesViewModel

@{
    ViewData["Title"] = "Details";
}

<h1 class="boxed">Details</h1>

<div class="boxed">
    <h4>Actor</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Actor.Name)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Actor.Name)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Actor.Gender)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Actor.Gender)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Actor.Age)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Actor.Age)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Actor.IMDBLink)
        </dt>
        <dd class = "col-sm-10">
            <a href="@Model.Actor.IMDBLink" target="_blank">
                IMDB
            </a>
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Actor.Photo)
        </dt>
        <dd class = "col-sm-10">
            @if (Model.Actor.Photo != null)
            {
                <img src="data:image/jpeg;base64,@Convert.ToBase64String(Model.Actor.Photo)"
                     alt="Actor Photo"
                     style="max-width:200px;" />
            }
            else
            {
                <p>No poster available.</p>
            }
        </dd>
    </dl>
</div>


<div class="boxed">
    <h3>Movies</h3>

    <table class="table table-striped">
        <thead>
            <tr>
                <th>Title</th>
                <th>Release Year</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in Model.ActorMovies)
            {
                <tr>
                    <td>@item?.Title</td>
                    <td>@item?.ReleaseYear</td>
                </tr>
            }
        </tbody>
    </table>
</div>
    

<div class="boxed">
    <h3>Tweets: @($"{Model.Reviews!.SentimentAvg:F3}")</h3>

    <table class="table table-striped">
        <thead>
            <tr>
                <th>Tweet</th>
                <th>Sentiment</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in Model.Reviews!.Reviews)
            {
                <tr>
                    <td>@item.ReviewStr</td>
                    <td>@item.Sentiment</td>
                </tr>
            }
        </tbody>
    </table>
</div>


<div>
    <a asp-action="Edit" asp-route-id="@Model?.Actor.Id">Edit</a> |
    <a asp-action="Index">Back to List</a>
</div>
