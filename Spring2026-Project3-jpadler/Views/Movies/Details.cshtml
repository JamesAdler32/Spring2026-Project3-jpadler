@model Spring2026_Project3_jpadler.Models.MovieActorsViewModel

@{
    ViewData["Title"] = "Details";
}

<h1>Details</h1>

<div>
    <h4>Movie</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Movie.Title)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Movie.Title)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Movie.IMDBLink)
        </dt>
        <dd class = "col-sm-10">
            <a href="@Model.Movie.IMDBLink" target="_blank">
                IMDB
            </a>
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Movie.Genre)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Movie.Genre)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Movie.ReleaseYear)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Movie.ReleaseYear)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Movie.Poster)
        </dt>
        <dd class = "col-sm-10">
            @if (Model.Movie.Poster != null)
            {
                <img src="data:image/jpeg;base64,@Convert.ToBase64String(Model.Movie.Poster)"
                     alt="Movie Poster"
                     style="max-width:200px;" />
            }
            else
            {
                <p>No poster available.</p>
            }
        </dd>
    </dl>
</div>


<div>
    <h3>Actors</h3>

    <table class="table table-striped">
        <thead>
            <tr>
                <th>Name</th>
                <th>Age</th>
            </tr>
        </thead>

        <tbody>
        @foreach (var item in Model.MovieActors)
        {
            <tr>
                <td>@item?.Name</td>
                <td>@item?.Age</td>
            </tr>
        }
        </tbody>
    </table>
</div>

    

<div>
    <h3>Reviews: @($"{Model.Reviews!.SentimentAvg:F3}")</h3>

    <table class="table">
        <thead>
            <tr>
                <th>Review</th>
                <th>Sentiment</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in Model.Reviews!.Reviews)
            {
                <tr>
                    <td>@item.ReviewStr</td>
                    <td>@item.Sentiment</td>
                </tr>
            }
        </tbody>
    </table>
</div>


<div>
    <a asp-action="Edit" asp-route-id="@Model?.Movie.Id">Edit</a> |
    <a asp-action="Index">Back to List</a>
</div>
